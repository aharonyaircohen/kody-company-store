{
  "adapter": "kody-engine-profile",
  "inputBindings": {},
  "outputBindings": {},
  "requirements": {},
  "role": "primitive",
  "phase": "reviewing",
  "claudeCode": {
    "model": "inherit",
    "permissionMode": "default",
    "maxTurns": 18,
    "maxThinkingTokens": 8000,
    "systemPromptAppend": null,
    "cacheable": true,
    "tools": [
      "Read",
      "Grep",
      "Glob",
      "Bash",
      "Agent",
      "mcp__codegraph"
    ],
    "hooks": [
      "block-write"
    ],
    "skills": [
      "code-review"
    ],
    "commands": [],
    "subagents": [
      "review-security",
      "review-reliability",
      "review-maintainability",
      "review-complexity"
    ],
    "plugins": [],
    "mcpServers": [
      {
        "name": "codegraph",
        "command": "codegraph",
        "args": [
          "serve",
          "--mcp"
        ]
      }
    ]
  },
  "cliTools": [],
  "scripts": {
    "preflight": [
      {
        "shell": "scripts/install-codegraph.sh"
      },
      {
        "script": "setLifecycleLabel",
        "with": {
          "label": "kody:reviewing",
          "color": "d93f0b",
          "description": "kody: reviewing a PR"
        }
      },
      {
        "script": "reviewFlow"
      },
      {
        "script": "loadTaskState"
      },
      {
        "script": "loadConventions"
      },
      {
        "script": "buildSyntheticPlugin"
      },
      {
        "script": "composePrompt"
      }
    ],
    "postflight": [
      {
        "script": "postReviewResult"
      },
      {
        "script": "saveTaskState"
      },
      {
        "script": "advanceFlow"
      }
    ]
  },
  "inputs": [
    {
      "name": "pr",
      "flag": "--pr",
      "type": "int",
      "required": true,
      "describe": "GitHub PR number to review."
    }
  ]
}
