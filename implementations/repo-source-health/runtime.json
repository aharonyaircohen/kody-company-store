{
  "adapter": "kody-engine-profile",
  "inputBindings": {},
  "outputBindings": {},
  "requirements": {},
  "role": "primitive",
  "kind": "oneshot",
  "claudeCode": {
    "model": "inherit",
    "permissionMode": "default",
    "maxTurns": 0,
    "maxThinkingTokens": null,
    "systemPromptAppend": null,
    "cacheable": true,
    "tools": [],
    "hooks": [],
    "skills": [],
    "commands": [],
    "subagents": [],
    "plugins": [],
    "mcpServers": []
  },
  "cliTools": [
    "gh",
    "git",
    "node",
    "corepack"
  ],
  "scripts": {
    "preflight": [
      {
        "shell": "scripts/run-repo-source-health.sh",
        "timeoutSec": 5400
      },
      {
        "script": "skipAgent"
      }
    ],
    "postflight": []
  },
  "capabilityKind": "observe",
  "readsFrom": [
    "kody.config.json",
    "source"
  ],
  "writesTo": [
    "commit-status"
  ],
  "inputs": [],
  "outputContract": {
    "actionTypes": [
      "REPO_SOURCE_HEALTH_CHECKED",
      "REPO_SOURCE_HEALTH_FAILED",
      "AGENT_NOT_RUN"
    ]
  }
}
