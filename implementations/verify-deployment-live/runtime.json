{
  "adapter": "kody-engine-profile",
  "inputBindings": {},
  "outputBindings": {},
  "requirements": {},
  "role": "utility",
  "kind": "oneshot",
  "claudeCode": {
    "model": "inherit",
    "permissionMode": "acceptEdits",
    "maxTurns": 0,
    "maxThinkingTokens": null,
    "systemPromptAppend": null,
    "tools": [],
    "hooks": [],
    "skills": [],
    "commands": [],
    "subagents": [],
    "plugins": [],
    "mcpServers": []
  },
  "cliTools": [
    "curl"
  ],
  "inputArtifacts": [],
  "outputArtifacts": [],
  "scripts": {
    "preflight": [
      {
        "shell": "check.sh"
      },
      {
        "script": "skipAgent"
      }
    ],
    "postflight": [
      {
        "script": "applyCapabilityReports"
      }
    ]
  },
  "inputs": [
    {
      "name": "url",
      "flag": "--url",
      "type": "string",
      "required": true,
      "describe": "Deployment URL to verify."
    },
    {
      "name": "expected-status",
      "flag": "--expected-status",
      "type": "int",
      "required": false,
      "describe": "Expected HTTP status. Default 200."
    },
    {
      "name": "goal",
      "flag": "--goal",
      "type": "string",
      "required": false,
      "describe": "Managed goal id to report deployment evidence to."
    },
    {
      "name": "evidence",
      "flag": "--evidence",
      "type": "string",
      "required": false,
      "describe": "Evidence key to set on the goal. Default deploymentLive."
    }
  ]
}
