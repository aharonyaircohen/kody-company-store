{
  "adapter": "kody-engine-profile",
  "inputBindings": {},
  "outputBindings": {},
  "requirements": {},
  "role": "watch",
  "kind": "oneshot",
  "claudeCode": {
    "model": "inherit",
    "permissionMode": "default",
    "maxTurns": 0,
    "systemPromptAppend": null,
    "cacheable": true,
    "enableVerifyTool": false,
    "tools": [],
    "hooks": [],
    "skills": [],
    "commands": [],
    "subagents": [],
    "plugins": [],
    "mcpServers": []
  },
  "cliTools": [
    {
      "name": "git",
      "install": {
        "required": true,
        "checkCommand": "command -v git"
      },
      "verify": "git --version",
      "usage": "Commits and pushes promoted memory files when not in dry-run or no-commit mode.",
      "allowedUses": [
        "status",
        "add",
        "commit",
        "push"
      ]
    }
  ],
  "inputArtifacts": [],
  "outputArtifacts": [],
  "scripts": {
    "preflight": [
      {
        "script": "runScheduledImplementationTick",
        "with": {
          "jobsDir": ".kody/capabilities",
          "slugArg": "capability",
          "shell": "tick.sh",
          "fenceLabel": "kody-job-next-state"
        }
      }
    ],
    "postflight": [
      {
        "script": "writeJobStateFile",
        "with": {
          "jobsDir": ".kody/capabilities"
        }
      },
      {
        "script": "appendCompanyActivity"
      }
    ]
  },
  "inputs": [
    {
      "name": "capability",
      "flag": "--capability",
      "type": "string",
      "required": true,
      "describe": "Runtime capability slug whose sidecar state is loaded and updated."
    }
  ]
}
