{
  "adapter": "kody-engine-profile",
  "inputBindings": {},
  "outputBindings": {},
  "requirements": {},
  "role": "primitive",
  "claudeCode": {
    "model": "inherit",
    "permissionMode": "acceptEdits",
    "maxTurns": null,
    "maxTurnTimeoutSec": 900,
    "systemPromptAppend": null,
    "tools": [
      "Read",
      "Write",
      "Edit",
      "Bash",
      "Grep",
      "Glob"
    ],
    "hooks": [
      "block-git"
    ],
    "skills": [
      "bug-reproduction"
    ],
    "commands": [],
    "subagents": [],
    "plugins": [],
    "mcpServers": []
  },
  "cliTools": [],
  "scripts": {
    "preflight": [
      {
        "script": "setLifecycleLabel",
        "with": {
          "label": "kody:reproducing",
          "color": "fef2c0",
          "description": "kody: writing a failing test that reproduces the bug"
        }
      },
      {
        "script": "runFlow"
      },
      {
        "script": "loadTaskState"
      },
      {
        "script": "loadConventions"
      },
      {
        "script": "loadCoverageRules"
      },
      {
        "script": "buildSyntheticPlugin"
      },
      {
        "script": "composePrompt"
      }
    ],
    "postflight": [
      {
        "script": "parseAgentResult"
      },
      {
        "script": "parseReproOutput"
      },
      {
        "script": "verifyReproFails"
      },
      {
        "script": "abortUnfinishedGitOps"
      },
      {
        "script": "commitAndPush"
      },
      {
        "script": "postIssueComment"
      },
      {
        "script": "persistArtifacts"
      },
      {
        "script": "writeAgentRunSummary"
      },
      {
        "script": "saveTaskState"
      },
      {
        "script": "advanceFlow"
      }
    ]
  },
  "inputs": [
    {
      "name": "issue",
      "flag": "--issue",
      "type": "int",
      "required": true,
      "describe": "GitHub issue number to reproduce."
    }
  ],
  "outputContract": {
    "actionTypes": [
      "REPRODUCE_COMPLETED",
      "REPRODUCE_FAILED",
      "AGENT_NOT_RUN"
    ],
    "artifacts": [
      {
        "name": "repro",
        "format": "markdown",
        "from": "prSummary"
      },
      {
        "name": "repro.testPath",
        "format": "text",
        "from": "reproTestPath"
      },
      {
        "name": "repro.failureSignature",
        "format": "text",
        "from": "reproFailureSignature"
      }
    ]
  }
}
