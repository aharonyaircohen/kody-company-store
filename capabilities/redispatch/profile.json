{
  "name": "redispatch",
  "role": "watch",
  "kind": "oneshot",
  "describe": "Detect stalled running Kody issues and plan or post resume actions.",
  "inputs": [
    {
      "name": "capability",
      "flag": "--capability",
      "type": "string",
      "required": true,
      "describe": "Runtime capability slug whose sidecar state is loaded and updated."
    }
  ],
  "claudeCode": {
    "model": "inherit",
    "permissionMode": "default",
    "maxTurns": 0,
    "systemPromptAppend": null,
    "cacheable": true,
    "enableVerifyTool": false,
    "tools": [],
    "hooks": [],
    "skills": [],
    "commands": [],
    "subagents": [],
    "plugins": [],
    "mcpServers": []
  },
  "cliTools": [
    {
      "name": "gh",
      "install": {
        "required": true,
        "checkCommand": "command -v gh"
      },
      "verify": "gh auth status",
      "usage": "Reads issues, comments, workflow runs, and posts resume/stuck comments when live.",
      "allowedUses": [
        "issue",
        "api"
      ]
    }
  ],
  "inputArtifacts": [],
  "outputArtifacts": [],
  "scripts": {
    "preflight": [
      {
        "script": "runScheduledImplementationTick",
        "with": {
          "jobsDir": ".kody/capabilities",
          "slugArg": "capability",
          "shell": "tick.sh",
          "fenceLabel": "kody-job-next-state"
        }
      }
    ],
    "postflight": [
      {
        "script": "writeJobStateFile",
        "with": {
          "jobsDir": ".kody/capabilities"
        }
      },
      {
        "script": "appendCompanyActivity"
      }
    ]
  },
  "action": "redispatch",
  "agent": "kody"
}
