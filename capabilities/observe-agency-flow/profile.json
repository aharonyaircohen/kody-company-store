{
  "name": "observe-agency-flow",
  "role": "primitive",
  "kind": "oneshot",
  "describe": "Read agency pipeline evidence (stale review PRs, unanswered requests, idle findings) and write one Observation plus the current agency-flow Finding.",
  "inputs": [],
  "claudeCode": {
    "model": "inherit",
    "permissionMode": "default",
    "maxTurns": 0,
    "maxThinkingTokens": null,
    "systemPromptAppend": null,
    "cacheable": true,
    "tools": [],
    "hooks": [],
    "skills": [],
    "commands": [],
    "subagents": [],
    "plugins": [],
    "mcpServers": []
  },
  "cliTools": ["gh", "node"],
  "scripts": {
    "preflight": [{ "shell": "run-observe-agency-flow.sh" }, { "script": "skipAgent" }],
    "postflight": [{ "script": "publishReport" }]
  },
  "output": {
    "result": {
      "facts": ["observation", "finding"]
    },
    "actionTypes": ["AGENCY_FLOW_OBSERVED", "AGENCY_FLOW_OBSERVATION_FAILED", "AGENT_NOT_RUN"]
  },
  "agent": "coo",
  "capabilityKind": "observe",
  "implementations": ["observe-agency-flow"],
  "readsFrom": ["agency-flow"],
  "writesTo": ["observations"]
}
