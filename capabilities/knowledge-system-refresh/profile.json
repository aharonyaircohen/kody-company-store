{
  "name": "knowledge-system-refresh",
  "role": "primitive",
  "kind": "oneshot",
  "describe": "Build and publish the current repository's Knowledge System graph.",
  "inputs": [],
  "claudeCode": {
    "model": "inherit",
    "permissionMode": "default",
    "maxTurns": 0,
    "maxThinkingTokens": null,
    "systemPromptAppend": null,
    "cacheable": true,
    "tools": [],
    "hooks": [],
    "skills": [],
    "commands": [],
    "subagents": [],
    "plugins": [],
    "mcpServers": []
  },
  "cliTools": ["gh", "git", "jq", "curl", "uv"],
  "scripts": {
    "preflight": [
      { "shell": "refresh-knowledge-system.sh", "timeoutSec": 5400 },
      { "script": "skipAgent" }
    ],
    "postflight": []
  },
  "output": {
    "actionTypes": [
      "KNOWLEDGE_SYSTEM_REFRESHED",
      "KNOWLEDGE_SYSTEM_FAILED",
      "AGENT_NOT_RUN"
    ]
  },
  "action": "knowledge-system-refresh",
  "agent": "cto",
  "capabilityKind": "observe",
  "implementations": ["knowledge-system-refresh"],
  "readsFrom": ["source", "kody-backend", "github-issues", "github-pull-requests"],
  "writesTo": ["knowledge-system"]
}
