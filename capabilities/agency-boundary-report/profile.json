{
  "name": "agency-boundary-report",
  "role": "primitive",
  "kind": "oneshot",
  "describe": "Create an AI Agency boundary eval recommendation report from recent engine eval facts.",
  "inputs": [
    {
      "name": "issue",
      "flag": "--issue",
      "type": "int",
      "required": false,
      "describe": "Optional tester issue number used only to route manual workflow_dispatch runs."
    }
  ],
  "claudeCode": {
    "model": "inherit",
    "permissionMode": "default",
    "maxTurns": 0,
    "maxThinkingTokens": null,
    "systemPromptAppend": null,
    "cacheable": true,
    "tools": [],
    "hooks": [],
    "skills": [],
    "commands": [],
    "subagents": [],
    "plugins": [],
    "mcpServers": []
  },
  "cliTools": ["gh", "node"],
  "scripts": {
    "preflight": [
      {
        "shell": "run-agency-boundary-report.sh"
      },
      {
        "script": "skipAgent"
      }
    ],
    "postflight": []
  },
  "output": {
    "actionTypes": [
      "AGENCY_BOUNDARY_REPORT_COMPLETED",
      "AGENCY_BOUNDARY_REPORT_FAILED",
      "AGENT_NOT_RUN"
    ]
  },
  "agent": "coo",
  "capabilityKind": "observe",
  "implementations": ["agency-boundary-report"],
  "readsFrom": ["github-workflow-logs", "kody.config.json"],
  "writesTo": ["reports/agency-boundary-report/runs"]
}
