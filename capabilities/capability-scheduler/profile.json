{
  "name": "capability-scheduler",
  "internal": true,
  "role": "watch",
  "describe": "Compatibility capability helper. Goals and loops own capability fan-out; this helper does not create schedule.",
  "kind": "oneshot",
  "inputs": [
    {
      "name": "capability",
      "flag": "--capability",
      "type": "string",
      "required": false,
      "describe": "Optional capability slug for legacy explicit runs. Scheduled fan-out belongs to goals and loops."
    }
  ],
  "claudeCode": {
    "model": "inherit",
    "permissionMode": "default",
    "maxTurns": null,
    "maxThinkingTokens": null,
    "systemPromptAppend": null,
    "tools": [],
    "hooks": [],
    "skills": [],
    "commands": [],
    "subagents": [],
    "plugins": [],
    "mcpServers": []
  },
  "cliTools": [
    {
      "name": "gh",
      "install": {
        "required": true,
        "checkCommand": "command -v gh"
      },
      "verify": "gh auth status",
      "usage": "",
      "allowedUses": [
        "api",
        "issue",
        "pr"
      ]
    }
  ],
  "inputArtifacts": [],
  "outputArtifacts": [],
  "scripts": {
    "preflight": [
      {
        "script": "dispatchCapabilityFileTicks",
        "with": {
          "jobsDir": ".kody/capabilities",
          "targetImplementation": "capability-tick",
          "slugArg": "capability",
          "requireExplicitCapability": true
        }
      }
    ],
    "postflight": []
  }
}
