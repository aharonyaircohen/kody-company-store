{
  "name": "repo-source-health",
  "role": "primitive",
  "kind": "oneshot",
  "describe": "Run the repository's configured source checks and publish one commit status for the Observer.",
  "inputs": [],
  "claudeCode": {
    "model": "inherit",
    "permissionMode": "default",
    "maxTurns": 0,
    "maxThinkingTokens": null,
    "systemPromptAppend": null,
    "cacheable": true,
    "tools": [],
    "hooks": [],
    "skills": [],
    "commands": [],
    "subagents": [],
    "plugins": [],
    "mcpServers": []
  },
  "cliTools": ["gh", "git", "node", "corepack"],
  "scripts": {
    "preflight": [
      { "shell": "run-repo-source-health.sh", "timeoutSec": 5400 },
      { "script": "skipAgent" }
    ],
    "postflight": []
  },
  "output": {
    "actionTypes": ["REPO_SOURCE_HEALTH_CHECKED", "REPO_SOURCE_HEALTH_FAILED", "AGENT_NOT_RUN"]
  },
  "action": "repo-source-health",
  "agent": "coo",
  "capabilityKind": "observe",
  "implementations": ["repo-source-health"],
  "readsFrom": ["kody.config.json", "source"],
  "writesTo": ["commit-status"]
}
