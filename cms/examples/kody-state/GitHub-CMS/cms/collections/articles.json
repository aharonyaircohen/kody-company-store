{
  "name": "articles",
  "label": "Articles",
  "adapter": "github",
  "mcpName": "article",
  "source": {
    "path": "content/articles",
    "extension": "json",
    "idField": "id"
  },
  "titleField": "title",
  "searchFields": [
    "title",
    "summary"
  ],
  "writePolicy": "enabled",
  "operations": {
    "list": true,
    "get": true,
    "search": true,
    "create": true,
    "update": true,
    "delete": true
  },
  "defaultSort": [
    {
      "field": "updatedAt",
      "direction": "desc"
    }
  ],
  "fields": [
    {
      "name": "id",
      "type": "id",
      "label": "ID",
      "readOnly": true
    },
    {
      "name": "title",
      "type": "text",
      "label": "Title",
      "required": true,
      "display": {
        "role": "primary",
        "width": "fill"
      },
      "validation": {
        "minLength": 3,
        "maxLength": 120
      }
    },
    {
      "name": "summary",
      "type": "textarea",
      "label": "Summary",
      "display": {
        "role": "secondary",
        "width": "fill"
      }
    },
    {
      "name": "status",
      "type": "select",
      "label": "Status",
      "options": [
        "draft",
        "review",
        "published"
      ],
      "required": true,
      "display": {
        "role": "meta",
        "width": "sm"
      }
    },
    {
      "name": "tags",
      "type": "multiSelect",
      "label": "Tags",
      "options": [
        "docs",
        "product",
        "support"
      ]
    },
    {
      "name": "body",
      "type": "textarea",
      "label": "Body"
    },
    {
      "name": "updatedAt",
      "type": "date",
      "label": "Updated At",
      "readOnly": true,
      "display": {
        "role": "meta",
        "format": "datetime",
        "width": "md"
      }
    }
  ],
  "filters": [
    {
      "field": "title",
      "operators": [
        "contains",
        "equals"
      ]
    },
    {
      "field": "status",
      "operators": [
        "equals",
        "in"
      ]
    },
    {
      "field": "tags",
      "operators": [
        "contains"
      ]
    }
  ]
}
