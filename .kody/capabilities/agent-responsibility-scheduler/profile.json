{
  "name": "agent-responsibility-scheduler",
  "role": "watch",
  "describe": "Compatibility agentResponsibility helper. Goals and loops own responsibility fan-out; this helper does not create schedule.",
  "kind": "oneshot",
  "inputs": [
    {
      "name": "agentResponsibility",
      "flag": "--agentResponsibility",
      "type": "string",
      "required": false,
      "describe": "Optional agentResponsibility slug for legacy explicit runs. Scheduled fan-out belongs to goals and loops."
    }
  ],
  "claudeCode": {
    "model": "inherit",
    "permissionMode": "default",
    "maxTurns": null,
    "maxThinkingTokens": null,
    "systemPromptAppend": null,
    "tools": [],
    "hooks": [],
    "skills": [],
    "commands": [],
    "subagents": [],
    "plugins": [],
    "mcpServers": []
  },
  "cliTools": [
    {
      "name": "gh",
      "install": {
        "required": true,
        "checkCommand": "command -v gh"
      },
      "verify": "gh auth status",
      "usage": "",
      "allowedUses": [
        "api",
        "issue",
        "pr"
      ]
    }
  ],
  "inputArtifacts": [],
  "outputArtifacts": [],
  "scripts": {
    "preflight": [
      {
        "script": "dispatchAgentResponsibilityFileTicks",
        "with": {
          "jobsDir": ".kody/agent-responsibilities",
          "targetAgentAction": "agent-responsibility-tick",
          "slugArg": "agentResponsibility",
          "requireExplicitAgentResponsibility": true
        }
      }
    ],
    "postflight": []
  }
}
