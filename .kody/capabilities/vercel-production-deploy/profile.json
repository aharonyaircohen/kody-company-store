{
  "name": "vercel-production-deploy",
  "role": "primitive",
  "describe": "Deploy main branch to Vercel Production. Requires Kody secrets VERCEL_ACCESS_TOKEN, VERCEL_ORG_ID, and VERCEL_PROJECT_ID.",
  "inputs": [
    {
      "name": "goal",
      "flag": "--goal",
      "type": "string",
      "required": false,
      "describe": "Managed goal id to report production deployment evidence to."
    }
  ],
  "claudeCode": {
    "model": "inherit",
    "permissionMode": "default",
    "maxTurns": 0,
    "maxTurnTimeoutSec": 1200,
    "systemPromptAppend": null,
    "cacheable": true,
    "tools": [],
    "hooks": [],
    "skills": [],
    "commands": [],
    "subagents": [],
    "plugins": [],
    "mcpServers": []
  },
  "cliTools": [],
  "scripts": {
    "preflight": [
      {
        "shell": "vercel-production-deploy.sh"
      },
      {
        "script": "skipAgent"
      }
    ],
    "postflight": [
      {
        "script": "applyAgentResponsibilityReports"
      },
      {
        "script": "appendCompanyActivity"
      }
    ]
  },
  "output": {
    "actionTypes": [
      "VERCEL_PRODUCTION_DEPLOY_COMPLETED",
      "VERCEL_PRODUCTION_DEPLOY_FAILED",
      "AGENT_NOT_RUN"
    ]
  },
  "action": "vercel-production-deploy",
  "agent": "cto",
  "mentions": [
    "aguyaharonyair"
  ],
  "capabilityKind": "act"
}
