{
  "name": "auto-sync",
  "role": "watch",
  "kind": "oneshot",
  "describe": "Scan stale mergeable PR branches and dispatch sync comments.",
  "inputs": [
    {
      "name": "agentResponsibility",
      "flag": "--agentResponsibility",
      "type": "string",
      "required": true,
      "describe": "Runtime agentResponsibility slug whose sidecar state is loaded and updated."
    }
  ],
  "claudeCode": {
    "model": "inherit",
    "permissionMode": "default",
    "maxTurns": 0,
    "systemPromptAppend": null,
    "cacheable": true,
    "enableVerifyTool": false,
    "tools": [],
    "hooks": [],
    "skills": [],
    "commands": [],
    "subagents": [],
    "plugins": [],
    "mcpServers": []
  },
  "cliTools": [
    {
      "name": "gh",
      "install": {
        "required": true,
        "checkCommand": "command -v gh"
      },
      "verify": "gh auth status",
      "usage": "Reads PRs, compares branches, and posts sync or stuck comments.",
      "allowedUses": [
        "pr",
        "api"
      ]
    },
    {
      "name": "jq",
      "install": {
        "required": true,
        "checkCommand": "command -v jq"
      },
      "verify": "jq --version",
      "usage": "Filters PR JSON and builds next-state JSON.",
      "allowedUses": [
        "json"
      ]
    }
  ],
  "inputArtifacts": [],
  "outputArtifacts": [],
  "scripts": {
    "preflight": [
      {
        "script": "runScheduledAgentActionTick",
        "with": {
          "jobsDir": ".kody/agent-responsibilities",
          "slugArg": "agentResponsibility",
          "shell": "tick.sh",
          "fenceLabel": "kody-job-next-state"
        }
      }
    ],
    "postflight": [
      {
        "script": "writeJobStateFile",
        "with": {
          "jobsDir": ".kody/agent-responsibilities"
        }
      },
      {
        "script": "appendCompanyActivity"
      }
    ]
  },
  "action": "auto-sync",
  "capabilityKind": "act",
  "agent": "kody"
}
