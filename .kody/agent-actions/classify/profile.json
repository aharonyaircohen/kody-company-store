{
  "name": "classify",
  "role": "primitive",
  "describe": "Classify an issue into one of {feature, bug, spec, chore} and dispatch the matching sub-orchestrator. Label-first fast path; LLM fallback when labels don't decide.",
  "inputs": [
    {
      "name": "issue",
      "flag": "--issue",
      "type": "int",
      "required": true,
      "describe": "GitHub issue number to classify."
    },
    {
      "name": "base",
      "flag": "--base",
      "type": "string",
      "required": false,
      "describe": "Optional safe base branch override for manual branch targeting."
    }
  ],
  "claudeCode": {
    "model": "inherit",
    "permissionMode": "default",
    "maxTurns": null,
    "maxThinkingTokens": null,
    "systemPromptAppend": null,
    "cacheable": true,
    "tools": [
      "Read",
      "Bash"
    ],
    "hooks": [],
    "skills": [
      "issue-classification"
    ],
    "commands": [],
    "subagents": [],
    "plugins": [],
    "mcpServers": []
  },
  "cliTools": [],
  "scripts": {
    "preflight": [
      {
        "script": "setLifecycleLabel",
        "with": {
          "label": "kody:classifying",
          "color": "0e8a16",
          "description": "kody: classifying the issue"
        }
      },
      {
        "script": "loadIssueContext"
      },
      {
        "script": "loadTaskState"
      },
      {
        "script": "classifyByLabel"
      },
      {
        "script": "loadConventions"
      },
      {
        "script": "buildSyntheticPlugin"
      },
      {
        "script": "composePrompt"
      }
    ],
    "postflight": [
      {
        "script": "parseAgentResult"
      },
      {
        "script": "recordClassification"
      },
      {
        "script": "writeAgentRunSummary"
      },
      {
        "script": "dispatchClassified"
      }
    ]
  },
  "output": {
    "actionTypes": [
      "CLASSIFIED_AS_FEATURE",
      "CLASSIFIED_AS_BUG",
      "CLASSIFIED_AS_SPEC",
      "CLASSIFIED_AS_CHORE",
      "CLASSIFY_FAILED"
    ]
  },
  "action": "classify",
  "capabilityKind": "act",
  "agent": "kody"
}
