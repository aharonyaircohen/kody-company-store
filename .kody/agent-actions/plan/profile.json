{
  "name": "plan",
  "role": "primitive",
  "describe": "Research an issue and produce a concrete implementation plan as a comment. Read-only — no branches, no commits.",
  "inputs": [
    {
      "name": "issue",
      "flag": "--issue",
      "type": "int",
      "required": true,
      "describe": "GitHub issue number to work on."
    }
  ],
  "claudeCode": {
    "model": "inherit",
    "permissionMode": "acceptEdits",
    "maxTurns": null,
    "maxTurnTimeoutSec": 1200,
    "systemPromptAppend": null,
    "cacheable": true,
    "enableVerifyTool": false,
    "verifyAttempts": 4,
    "tools": [
      "Read",
      "Grep",
      "Glob",
      "Bash",
      "Agent",
      "mcp__codegraph"
    ],
    "hooks": [],
    "skills": [
      "implementation-planning",
      "design-system",
      "frontend-design",
      "shadcn",
      "vercel-react-best-practices",
      "next-best-practices"
    ],
    "commands": [],
    "subagents": [],
    "plugins": [],
    "mcpServers": [
      {
        "name": "codegraph",
        "command": "codegraph",
        "args": [
          "serve",
          "--mcp"
        ]
      }
    ]
  },
  "cliTools": [],
  "scripts": {
    "preflight": [
      {
        "shell": "install-codegraph.sh"
      },
      {
        "script": "loadIssueContext"
      },
      {
        "script": "buildSyntheticPlugin"
      },
      {
        "script": "composePrompt"
      }
    ],
    "postflight": [
      {
        "script": "parseAgentResult"
      },
      {
        "script": "postAgentComment"
      }
    ]
  }
}
