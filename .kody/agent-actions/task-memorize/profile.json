{
  "name": "task-memorize",
  "role": "primitive",
  "kind": "oneshot",
  "describe": "Turn task and execution experience into durable `.kody/memory/` entries.",
  "inputs": [],
  "claudeCode": {
    "model": "inherit",
    "permissionMode": "acceptEdits",
    "maxTurns": null,
    "maxThinkingTokens": null,
    "systemPromptAppend": null,
    "cacheable": true,
    "tools": [
      "Read",
      "Write",
      "Edit",
      "Bash",
      "Grep",
      "Glob"
    ],
    "hooks": [],
    "skills": [
      "task-memorize"
    ],
    "commands": [],
    "subagents": [],
    "plugins": [],
    "mcpServers": []
  },
  "cliTools": [
    {
      "name": "gh",
      "install": {
        "required": true,
        "checkCommand": "gh --version"
      },
      "verify": "gh auth status",
      "usage": "Read and write repository memory files when durable lessons are found.",
      "allowedUses": [
        "inspect task artifacts",
        "write memory files",
        "commit memory updates"
      ]
    }
  ],
  "scripts": {
    "preflight": [
      {
        "script": "buildSyntheticPlugin"
      },
      {
        "script": "composePrompt"
      }
    ],
    "postflight": [
      {
        "script": "parseAgentResult"
      }
    ]
  },
  "output": {
    "actionTypes": [
      "TASK_MEMORIZE_COMPLETED",
      "TASK_MEMORIZE_FAILED",
      "AGENT_NOT_RUN"
    ]
  }
}
