{
  "name": "task-memory-extractor",
  "role": "watch",
  "kind": "oneshot",
  "describe": "Promote high-confidence task memory recommendations into .kody/memory.",
  "inputs": [
    {
      "name": "agentResponsibility",
      "flag": "--agentResponsibility",
      "type": "string",
      "required": true,
      "describe": "Scheduled agentResponsibility slug whose sidecar state is loaded and updated."
    }
  ],
  "claudeCode": {
    "model": "inherit",
    "permissionMode": "default",
    "maxTurns": 0,
    "systemPromptAppend": null,
    "cacheable": true,
    "enableVerifyTool": false,
    "tools": [],
    "hooks": [],
    "skills": [],
    "commands": [],
    "subagents": [],
    "plugins": [],
    "mcpServers": []
  },
  "cliTools": [
    {
      "name": "git",
      "install": {
        "required": true,
        "checkCommand": "command -v git"
      },
      "verify": "git --version",
      "usage": "Commits and pushes promoted memory files when not in dry-run or no-commit mode.",
      "allowedUses": [
        "status",
        "add",
        "commit",
        "push"
      ]
    }
  ],
  "inputArtifacts": [],
  "outputArtifacts": [],
  "scripts": {
    "preflight": [
      {
        "script": "runScheduledAgentActionTick",
        "with": {
          "jobsDir": ".kody/agent-responsibilities",
          "slugArg": "agentResponsibility",
          "shell": "tick.sh",
          "fenceLabel": "kody-job-next-state"
        }
      }
    ],
    "postflight": [
      {
        "script": "writeJobStateFile",
        "with": {
          "jobsDir": ".kody/agent-responsibilities"
        }
      },
      {
        "script": "appendCompanyActivity"
      }
    ]
  },
  "action": "task-memory-extractor",
  "capabilityKind": "act",
  "agent": "coo",
  "every": "30m"
}
