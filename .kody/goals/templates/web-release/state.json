{
  "version": 1,
  "kind": "template",
  "templateId": "web-release",
  "state": "inactive",
  "type": "web-release",
  "description": "Shared managed goal template releasing a web app: prepare release, merge it to main through task leadership, then deploy Vercel production.",
  "destination": {
    "outcome": "Release is prepared, merged to main, and deployed to Vercel production.",
    "evidence": ["releasePrExists", "mainMerged", "productionDeployed"]
  },
  "agentResponsibilities": ["release", "release-merge", "vercel-production-deploy"],
  "route": [
    {
      "stage": "release",
      "evidence": "releasePrExists",
      "agentResponsibility": "release",
      "agentAction": "release-prepare",
      "args": {
        "issue": { "fact": "issue" },
        "goal": { "fact": "goalId" }
      }
    },
    {
      "stage": "merge",
      "evidence": "mainMerged",
      "agentResponsibility": "release-merge",
      "agentAction": "release-merge",
      "args": {
        "pr": { "fact": "releasePr" },
        "issue": { "fact": "issue" },
        "goal": { "fact": "goalId" }
      }
    },
    {
      "stage": "publish",
      "evidence": "productionDeployed",
      "agentResponsibility": "vercel-production-deploy",
      "agentAction": "vercel-production-deploy",
      "args": { "goal": { "fact": "goalId" } }
    }
  ],
  "stage": "release",
  "facts": {},
  "blockers": []
}
