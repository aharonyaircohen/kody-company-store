{
  "name": "task-verifier",
  "role": "primitive",
  "describe": "Task verifier — deep analysis of backlog issues, verdict to verified or needs-human.",
  "inputs": [
    {
      "name": "issue",
      "flag": "--issue",
      "type": "int",
      "required": true,
      "describe": "GitHub issue number to work on."
    }
  ],
  "claudeCode": {
    "model": "inherit",
    "permissionMode": "bypassPermissions",
    "maxTurns": null,
    "maxTurnTimeoutSec": 1200,
    "systemPromptAppend": null,
    "cacheable": true,
    "enableVerifyTool": false,
    "verifyAttempts": 4,
    "tools": [
      "Read",
      "Bash",
      "Grep",
      "Glob"
    ],
    "hooks": [],
    "skills": [
      "verifier-method"
    ],
    "commands": [],
    "subagents": [],
    "plugins": [],
    "mcpServers": []
  },
  "cliTools": [],
  "scripts": {
    "preflight": [
      {
        "script": "buildSyntheticPlugin"
      },
      {
        "script": "loadIssueContext"
      },
      {
        "script": "composePrompt"
      }
    ],
    "postflight": [
      {
        "script": "parseAgentResult"
      },
      {
        "script": "postAgentComment"
      }
    ]
  }
}
