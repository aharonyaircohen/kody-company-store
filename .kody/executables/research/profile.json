{
  "name": "research",
  "role": "primitive",
  "describe": "Research an issue: understand the ask, map relevant repo context, and surface clarifying questions + gaps. Read-only \u2014 no branches, no commits, no prescribed next steps.",
  "inputs": [
    {
      "name": "issue",
      "flag": "--issue",
      "type": "int",
      "required": true,
      "describe": "GitHub issue number to research."
    }
  ],
  "claudeCode": {
    "model": "inherit",
    "permissionMode": "default",
    "maxTurns": null,
    "systemPromptAppend": null,
    "cacheable": true,
    "tools": [
      "Read",
      "Grep",
      "Glob",
      "Bash",
      "Agent",
      "mcp__playwright",
      "mcp__codegraph"
    ],
    "hooks": ["block-write"],
    "skills": ["issue-research"],
    "commands": [],
    "subagents": ["research-scout"],
    "plugins": [],
    "mcpServers": [
      {
        "name": "playwright",
        "command": "npx",
        "args": [
          "-y",
          "--package=@playwright/mcp@latest",
          "--",
          "playwright-mcp"
        ]
      },
      {
        "name": "codegraph",
        "command": "codegraph",
        "args": ["serve", "--mcp"]
      }
    ]
  },
  "cliTools": [
    {
      "name": "playwright",
      "install": {
        "required": false,
        "checkCommand": "ls \"$HOME/.cache/ms-playwright\" 2>/dev/null | grep -q '^chromium'",
        "installCommand": "npx --yes playwright install --with-deps chromium"
      },
      "verify": "ls \"$HOME/.cache/ms-playwright\" 2>/dev/null | grep -q '^chromium'",
      "usage": ""
    }
  ],
  "scripts": {
    "preflight": [
      {
        "shell": "install-codegraph.sh"
      },
      {
        "script": "setLifecycleLabel",
        "with": {
          "label": "kody:researching",
          "color": "1d76db",
          "description": "kody: researching the issue"
        }
      },
      {
        "script": "diagMcp"
      },
      {
        "script": "loadIssueContext"
      },
      {
        "script": "loadTaskState"
      },
      {
        "script": "loadConventions"
      },
      {
        "script": "loadPriorArt"
      },
      {
        "script": "buildSyntheticPlugin"
      },
      {
        "script": "composePrompt"
      }
    ],
    "postflight": [
      {
        "script": "parseAgentResult"
      },
      {
        "script": "persistArtifacts"
      },
      {
        "script": "postResearchComment"
      },
      {
        "script": "writeRunSummary"
      },
      {
        "script": "saveTaskState"
      },
      {
        "script": "advanceFlow"
      }
    ]
  },
  "output": {
    "actionTypes": ["RESEARCH_COMPLETED", "RESEARCH_FAILED"],
    "artifacts": [
      {
        "name": "research",
        "format": "markdown",
        "from": "prSummary"
      },
      {
        "name": "priorArt",
        "format": "json",
        "from": "priorArt"
      }
    ]
  }
}
