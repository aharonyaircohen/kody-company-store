{
  "name": "release-state",
  "role": "utility",
  "kind": "oneshot",
  "describe": "Observe current release state and optionally report facts to a managed goal.",
  "inputs": [
    {
      "name": "goal",
      "flag": "--goal",
      "type": "string",
      "required": false,
      "describe": "Managed goal id to report release-state evidence to."
    },
    {
      "name": "evidence",
      "flag": "--evidence",
      "type": "string",
      "required": false,
      "describe": "Evidence key to set on the goal. Default releaseStateObserved."
    },
    {
      "name": "package",
      "flag": "--package",
      "type": "string",
      "required": false,
      "describe": "Package name to check in npm. Defaults to package.json name."
    }
  ],
  "claudeCode": {
    "model": "inherit",
    "permissionMode": "acceptEdits",
    "maxTurns": 0,
    "maxThinkingTokens": null,
    "systemPromptAppend": null,
    "tools": [],
    "hooks": [],
    "skills": [],
    "commands": [],
    "subagents": [],
    "plugins": [],
    "mcpServers": []
  },
  "cliTools": [
    "git",
    "gh",
    "npm"
  ],
  "inputArtifacts": [],
  "outputArtifacts": [],
  "scripts": {
    "preflight": [
      {
        "shell": "state.sh"
      },
      {
        "script": "skipAgent"
      }
    ],
    "postflight": [
      {
        "script": "applyDutyReports"
      }
    ]
  }
}
