{
  "name": "review",
  "role": "primitive",
  "phase": "reviewing",
  "describe": "Read-only structured review of an open PR. Posts one comment, never commits.",
  "inputs": [
    {
      "name": "pr",
      "flag": "--pr",
      "type": "int",
      "required": true,
      "describe": "GitHub PR number to review."
    }
  ],
  "claudeCode": {
    "model": "inherit",
    "permissionMode": "default",
    "maxTurns": null,
    "maxThinkingTokens": 8000,
    "systemPromptAppend": null,
    "cacheable": true,
    "tools": [
      "Read",
      "Grep",
      "Glob",
      "Bash",
      "Agent",
      "mcp__codegraph"
    ],
    "hooks": [
      "block-write"
    ],
    "skills": [
      "code-review",
      "design-system",
      "vercel-react-best-practices",
      "next-best-practices",
      "web-design-guidelines"
    ],
    "commands": [],
    "subagents": [
      "review-security",
      "review-correctness",
      "review-style",
      "review-architecture"
    ],
    "plugins": [],
    "mcpServers": [
      {
        "name": "codegraph",
        "command": "codegraph",
        "args": [
          "serve",
          "--mcp"
        ]
      }
    ]
  },
  "cliTools": [],
  "scripts": {
    "preflight": [
      {
        "shell": "install-codegraph.sh"
      },
      {
        "script": "setLifecycleLabel",
        "with": {
          "label": "kody:reviewing",
          "color": "d93f0b",
          "description": "kody: reviewing a PR"
        }
      },
      {
        "script": "reviewFlow"
      },
      {
        "script": "loadTaskState"
      },
      {
        "script": "loadConventions"
      },
      {
        "script": "buildSyntheticPlugin"
      },
      {
        "script": "composePrompt"
      }
    ],
    "postflight": [
      {
        "script": "postReviewResult"
      },
      {
        "script": "saveTaskState"
      },
      {
        "script": "advanceFlow"
      }
    ]
  }
}
