{
  "name": "vercel-dev-deploy",
  "role": "primitive",
  "describe": "Deploy dev branch to Vercel Preview and move the stable dev preview alias.",
  "inputs": [],
  "claudeCode": {
    "model": "inherit",
    "permissionMode": "default",
    "maxTurns": 0,
    "maxTurnTimeoutSec": 1200,
    "systemPromptAppend": null,
    "cacheable": true,
    "tools": [],
    "hooks": [],
    "skills": [],
